# Public (client-safe) — VITE_ prefix ships to the browser
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Optional: Python backend URL in production (Railway / Render 等)
# Leave empty locally — Vite dev proxy forwards /api to localhost:8000
VITE_API_URL=

# Server-only secrets — never use VITE_ prefix
WEATHER_API_KEY=
SENDGRID_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
RESERVATION_SYSTEM_NAME=店舗予約システム
RESERVATION_API_URL=
RESERVATION_API_KEY=
